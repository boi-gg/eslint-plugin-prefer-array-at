{
  "name": "@boi.gg/eslint-plugin-prefer-array-at",
  "version": "0.1.1",
  "license": "MIT",
  "private": false,
  "description": "ESLint plugin to prefer Array.prototype.at() over traditional indexing.",
  "repository": {
    "url": "git+https://github.com/boi-gg/eslint-plugin-prefer-array-at.git"
  },
  "readme": "https://github.com/boi-gg/eslint-plugin-prefer-array-at/blob/develop/README.md",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "format": "rimraf dist && tsdown && eslint --fix . && prettier --write .",
    "lint": "eslint ./src",
    "ci": "tsdown && tsc --noEmit && eslint ./src && vitest run --coverage && prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.36.0",
    "eslint-plugin-perfectionist": "^4.15.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsdown": "^0.14.2",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.44.0",
    "vitest": "^3.2.4"
  }
}
